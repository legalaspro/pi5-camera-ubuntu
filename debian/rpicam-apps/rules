#!/usr/bin/make -f
# Build rpicam-apps with DRM preview enabled and all heavyweight optional
# post-processing stages disabled (libav, EGL, Qt, OpenCV, TFLite, Hailo).

export DEB_BUILD_MAINT_OPTIONS = hardening=+all

%:
	dh $@ --buildsystem=meson

# Match the options used by scripts/build-rpicam-apps.sh.
override_dh_auto_configure:
	dh_auto_configure -- \
	    --buildtype=release \
	    -Denable_libav=disabled \
	    -Denable_drm=enabled \
	    -Denable_egl=disabled \
	    -Denable_qt=disabled \
	    -Denable_opencv=disabled \
	    -Denable_tflite=disabled \
	    -Denable_hailo=disabled
